# Copy this file to `.env` and fill in the single required secret.
# `make demo` reads `.env`; `docker compose` picks up each variable as the
# corresponding service requires it.

# --- Required ---------------------------------------------------------------

# Anthropic API key with access to claude-opus-4-7. The runtime backend
# exits at startup if this is empty.
ANTHROPIC_API_KEY=your-key-here

# --- Optional (sensible defaults) ------------------------------------------

# CORS allowlist for the ATW backend. Comma-separated. The default
# accepts the Aurelia storefront on localhost only.
# ALLOWED_ORIGINS=http://localhost:8000

# Optional server-side key for safe-read tools the ATW backend executes
# against the host API. Leave unset for anonymous host API calls.
# HOST_API_KEY=

# Runtime logging level (pino): trace, debug, info, warn, error, fatal.
# LOG_LEVEL=info

# Retrieval tuning; defaults per contracts/chat-endpoint.md §9.
# RETRIEVAL_SIMILARITY_THRESHOLD=0.55
# RETRIEVAL_TOP_K=8

# Conversation + tool-loop limits.
# MAX_CONVERSATION_TURNS=20
# MAX_TOOL_CALLS_PER_TURN=5

# Rate limit (requests per window per session).
# RATE_LIMIT_MAX=60
# RATE_LIMIT_WINDOW_MS=600000
