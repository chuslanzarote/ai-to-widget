import type {
  RuntimeErrorBody,
  RuntimeErrorCode,
} from "@atw/scripts/dist/lib/error-codes.js";

/**
 * Typed runtime errors per specs/003-runtime/contracts/chat-endpoint.md §7.
 * Handlers throw these; the Fastify error hook maps them to HTTP status +
 * user-safe JSON body.
 */
export class ValidationError extends Error {
  readonly code: RuntimeErrorCode;
  readonly status: number;
  readonly userMessage: string;
  constructor(userMessage: string, code: "validation_failed" | "message_too_long" = "validation_failed") {
    super(userMessage);
    this.code = code;
    this.status = 400;
    this.userMessage = userMessage;
  }
}

export class RetrievalError extends Error {
  readonly code = "retrieval_unavailable" as const;
  readonly status = 503;
  readonly userMessage = "Having trouble reaching the catalog. Please try again.";
}

export class ModelUnavailableError extends Error {
  readonly code = "model_unavailable" as const;
  readonly status = 503;
  readonly userMessage = "The assistant is offline for a moment. Please try again.";
}

export class HostApiError extends Error {
  readonly code = "host_api_unreachable" as const;
  readonly status = 503;
  readonly userMessage = "I can't reach the store right now to help with that.";
}

export type RuntimeError =
  | ValidationError
  | RetrievalError
  | ModelUnavailableError
  | HostApiError;

export function errorToResponse(
  err: unknown,
  requestId: string,
): { status: number; body: RuntimeErrorBody } {
  if (
    err instanceof ValidationError ||
    err instanceof RetrievalError ||
    err instanceof ModelUnavailableError ||
    err instanceof HostApiError
  ) {
    return {
      status: err.status,
      body: {
        error_code: err.code,
        message: err.userMessage,
        request_id: requestId,
      },
    };
  }
  return {
    status: 500,
    body: {
      error_code: "internal_error",
      message: "Something went wrong on our side.",
      request_id: requestId,
    },
  };
}
