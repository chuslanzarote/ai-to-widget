import type { FastifyInstance, FastifyRequest } from "fastify";

/**
 * Principle I enforcement: strip every credential-bearing header before any
 * route handler sees it. The count is logged (value never is) so operators
 * can spot widgets that are sending unnecessary auth to the backend.
 *
 * Invariant: the backend MUST NOT receive shopper cookies or tokens
 * (specs/003-runtime/contracts/chat-endpoint.md §4 step 2, §6).
 */
const FORBIDDEN_EXACT = new Set([
  "authorization",
  "cookie",
  "set-cookie",
]);
const FORBIDDEN_PATTERN = /^x-.*-(token|auth|session)$/i;

export function registerCredentialStrip(app: FastifyInstance): void {
  app.addHook("onRequest", async (req: FastifyRequest) => {
    let stripped = 0;
    const headers = req.headers as Record<string, unknown>;
    for (const key of Object.keys(headers)) {
      const lower = key.toLowerCase();
      if (
        FORBIDDEN_EXACT.has(lower) ||
        (FORBIDDEN_PATTERN.test(lower) && lower !== "x-atw-session-id")
      ) {
        delete headers[key];
        stripped += 1;
      }
    }
    if (stripped > 0) {
      req.log.warn(
        { credential_strip_total: stripped, req_id: req.id },
        "stripped credential-bearing headers from incoming request",
      );
    }
  });
}
