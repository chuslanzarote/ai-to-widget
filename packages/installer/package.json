{
  "name": "create-atw",
  "version": "0.1.0",
  "description": "Scaffold a new Ai to Widget project — installs the five /atw.* slash commands and the .atw/ skeleton.",
  "type": "module",
  "bin": {
    "create-atw": "./bin/create-atw.js"
  },
  "main": "./dist/index.js",
  "files": [
