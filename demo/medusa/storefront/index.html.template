<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Aurelia — Specialty Coffee</title>
  <link rel="stylesheet" href="/widget.css" />
  <style>
    :root {
      --atw-primary-color: #8B4513;
      --atw-primary-text-color: #ffffff;
      --atw-radius: 4px;
      --atw-font-family: "Inter", system-ui, -apple-system, sans-serif;

      --bg: #faf7f2;
      --ink: #2a1a0e;
      --muted: #6b4e35;
      --muted-2: #8a7560;
      --brand: #8B4513;
      --brand-dark: #6d3610;
      --line: #e8dfd2;
      --card-bg: #ffffff;
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; }
    body {
      margin: 0;
      font-family: var(--atw-font-family);
      background: var(--bg);
      color: var(--ink);
      line-height: 1.5;
    }
    a { color: inherit; text-decoration: none; }
    a:hover { color: var(--brand); }

    /* ─── Header ──────────────────────────────────── */
    header.site {
      position: sticky;
      top: 0;
      z-index: 50;
      background: rgba(250, 247, 242, .95);
      border-bottom: 1px solid var(--line);
      backdrop-filter: saturate(1.2) blur(6px);
    }
    nav.site {
      max-width: 1080px;
      margin: 0 auto;
      padding: 1rem 1.5rem;
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }
    nav.site .brand {
      font-weight: 500;
      font-size: 1.25rem;
      letter-spacing: -0.01em;
    }
    nav.site .spacer { flex: 1; }
    nav.site a.link {
      color: var(--muted);
      font-size: .95rem;
    }
    nav.site a.link:hover { color: var(--ink); }
    .badge {
      display: inline-block;
      min-width: 1.4em;
      padding: 0 .45em;
      margin-left: .25em;
      background: var(--brand);
      color: white;
      border-radius: 999px;
      font-size: .8rem;
      text-align: center;
      line-height: 1.4em;
    }

    main { max-width: 1080px; margin: 0 auto; padding: 2rem 1.5rem 5rem; }

    /* ─── Home: hero + grid ───────────────────────── */
    .hero { padding: 1.5rem 0 2rem; }
    .hero h1 { font-weight: 300; letter-spacing: -0.02em; margin: 0 0 .5rem; font-size: 2.5rem; }
    .hero p { color: var(--muted); margin: 0; max-width: 640px; }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-top: 1rem;
    }
    .card {
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(0,0,0,.06);
      display: flex;
      flex-direction: column;
      transition: transform .15s ease, box-shadow .15s ease;
    }
    .card:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 18px rgba(0,0,0,.10);
      color: inherit;
    }
    .card img { display: block; width: 100%; aspect-ratio: 1; object-fit: cover; background: #eee; }
    .card .body { padding: 1rem; flex: 1; display: flex; flex-direction: column; gap: .4rem; }
    .card h3 { margin: 0; font-size: 1rem; font-weight: 500; }
    .card .desc { margin: 0; color: var(--muted); font-size: .875rem; line-height: 1.4; flex: 1; }
    .card .price { margin-top: .25rem; color: var(--brand); font-size: .9rem; font-weight: 500; }

    /* ─── Product detail ─────────────────────────── */
    a.back { display: inline-block; margin-bottom: 1rem; color: var(--muted); font-size: .9rem; }
    .pdp {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
      margin-top: 1rem;
    }
    @media (min-width: 720px) {
      .pdp { grid-template-columns: 1fr 1fr; gap: 3rem; }
    }
    .pdp .gallery img { width: 100%; border-radius: 8px; aspect-ratio: 1; object-fit: cover; background: #eee; }
    .pdp h1 { font-weight: 300; letter-spacing: -0.02em; margin: 0 0 .5rem; font-size: 2rem; }
    .pdp .desc { color: var(--muted); margin-bottom: 1.5rem; }
    .pdp label { display: block; font-size: .85rem; color: var(--muted); margin-bottom: .4rem; font-weight: 500; }
    .pdp select, .pdp input[type=number] {
      padding: .55rem .75rem;
      border: 1px solid var(--line);
      border-radius: 6px;
      background: white;
      font: inherit;
      width: 100%;
      max-width: 320px;
    }
    .pdp .row { margin-bottom: 1.1rem; }
    .pdp .qty-input { max-width: 90px; }

    .btn {
      display: inline-block;
      padding: .7rem 1.1rem;
      border-radius: var(--atw-radius);
      border: 1px solid var(--line);
      background: white;
      color: var(--ink);
      font: inherit;
      font-weight: 500;
      cursor: pointer;
      transition: background .1s, border-color .1s, color .1s;
    }
    .btn:hover { border-color: var(--muted-2); }
    .btn.primary {
      background: var(--brand);
      color: white;
      border-color: var(--brand);
    }
    .btn.primary:hover { background: var(--brand-dark); border-color: var(--brand-dark); }

    .feedback { margin-top: 1rem; font-size: .9rem; color: transparent; transition: color .15s; }
    .feedback.success { color: #2d7a4b; }

    /* ─── Cart ───────────────────────────────────── */
    .cart h1 { font-weight: 300; margin-bottom: 1.5rem; }
    table.cart-table {
      width: 100%;
      border-collapse: collapse;
      background: var(--card-bg);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    .cart-table th, .cart-table td { padding: 1rem; text-align: left; border-bottom: 1px solid var(--line); }
    .cart-table th { font-weight: 500; color: var(--muted); font-size: .85rem; }
    .cart-table tfoot td { border-bottom: none; padding-top: 1.25rem; }
    .cart-item { display: flex; align-items: center; gap: .75rem; }
    .cart-item img { width: 48px; height: 48px; border-radius: 4px; object-fit: cover; }
    .align-right { text-align: right; }
    .qty-input-small {
      width: 70px;
      padding: .4rem;
      border: 1px solid var(--line);
      border-radius: 4px;
      font: inherit;
    }
    .remove-btn {
      background: transparent;
      border: none;
      color: var(--muted);
      cursor: pointer;
      font-size: 1.1rem;
      padding: .25rem .5rem;
    }
    .remove-btn:hover { color: #a33; }
    .cart-actions { display: flex; gap: .75rem; justify-content: flex-end; margin-top: 1.5rem; }
    .muted { color: var(--muted); font-size: .85rem; }

    /* ─── Account ────────────────────────────────── */
    .account h1 { font-weight: 300; margin-bottom: .75rem; }
    .account h2 { font-weight: 500; font-size: 1.1rem; margin-top: 2rem; }
    .login-buttons { display: flex; gap: .75rem; flex-wrap: wrap; margin-top: 1.5rem; }
    .account-header { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    .orders { display: grid; gap: 1rem; margin-top: 1rem; }
    .order {
      background: var(--card-bg);
      border-radius: 8px;
      padding: 1rem 1.25rem;
      box-shadow: 0 1px 3px rgba(0,0,0,.06);
    }
    .order header {
      display: flex;
      align-items: baseline;
      gap: .75rem;
      margin-bottom: .5rem;
    }
    .order ul { margin: 0; padding-left: 1.25rem; color: var(--muted); font-size: .9rem; }

    /* ─── States ─────────────────────────────────── */
    .state { padding: 3rem 0; text-align: center; color: var(--muted); }
    .state.error { color: #a33; }
    .empty { padding: 4rem 0; text-align: center; }
    .empty h1 { font-weight: 300; }

    footer.site {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--line);
      color: var(--muted-2);
      font-size: .8rem;
      text-align: center;
    }
  </style>
</head>
<body>
  <header class="site">
    <nav class="site">
      <a href="#/" class="brand">Aurelia</a>
      <div class="spacer"></div>
      <a href="#/account" class="link" id="nav-account">Sign in</a>
      <a href="#/cart" class="link">Cart<span class="badge" id="cart-count">0</span></a>
    </nav>
  </header>

  <main id="app">
    <div class="state">Loading…</div>
  </main>

  <footer class="site">
    <div style="max-width:1080px;margin:0 auto;padding:0 1.5rem 2rem;">
      This is the AI to Widget demo storefront. Products, customers and orders are synthetic data. No real checkout happens.
    </div>
  </footer>

  <script>
    // ──────────────── Config (injected by entrypoint envsubst) ──
    const MEDUSA_URL = "${MEDUSA_BACKEND_URL}";
    const PK         = "${MEDUSA_PUBLISHABLE_KEY}";
    let REGION_ID    = null;

    // ──────────────── Utilities ────────────────────────────────
    const $ = (s, ctx) => (ctx || document).querySelector(s);
    const $$ = (s, ctx) => Array.from((ctx || document).querySelectorAll(s));
    const esc = (s) => String(s == null ? "" : s).replace(/[&<>"']/g, c => ({
      "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;"
    }[c]));
    const fmt = (cents, currency) => {
      currency = (currency || "eur").toUpperCase();
      try {
        return new Intl.NumberFormat("en", { style: "currency", currency }).format((cents || 0) / 100);
      } catch (e) { return ((cents || 0) / 100).toFixed(2) + " " + currency; }
    };

    // ──────────────── API ──────────────────────────────────────
    async function api(path) {
      const u = new URL(MEDUSA_URL + path);
      if (REGION_ID && !u.searchParams.has("region_id")) u.searchParams.set("region_id", REGION_ID);
      const res = await fetch(u.toString(), { headers: { "x-publishable-api-key": PK } });
      if (!res.ok) throw new Error("HTTP " + res.status);
      return res.json();
    }
    async function initRegion() {
      const r = await fetch(MEDUSA_URL + "/store/regions", {
        headers: { "x-publishable-api-key": PK }
      });
      if (!r.ok) throw new Error("HTTP " + r.status);
      const data = await r.json();
      REGION_ID = (data.regions || [])[0] && data.regions[0].id;
    }

    // ──────────────── Cart (localStorage) ──────────────────────
    const CartStore = {
      key: "aurelia.cart",
      items() { try { return JSON.parse(localStorage.getItem(this.key) || "[]"); } catch (e) { return []; } },
      save(items) { localStorage.setItem(this.key, JSON.stringify(items)); refreshCartBadge(); },
      count() { return this.items().reduce((n, i) => n + i.quantity, 0); },
      subtotal() { return this.items().reduce((n, i) => n + i.price * i.quantity, 0); },
      add(product, variant, quantity) {
        const items = this.items();
        const existing = items.find(i => i.variant_id === variant.id);
        if (existing) existing.quantity += quantity;
        else items.push({
          variant_id: variant.id,
          product_id: product.id,
          handle: product.handle,
          title: product.title,
          variant_title: variant.title,
          price: (variant.calculated_price && variant.calculated_price.calculated_amount) || 0,
          currency: (variant.calculated_price && variant.calculated_price.currency_code) || "eur",
          image: product.thumbnail,
          quantity: quantity,
        });
        this.save(items);
      },
      update(variant_id, quantity) {
        let items = this.items();
        if (quantity <= 0) items = items.filter(i => i.variant_id !== variant_id);
        else {
          const it = items.find(i => i.variant_id === variant_id);
          if (it) it.quantity = quantity;
        }
        this.save(items);
      },
      clear() { this.save([]); },
    };
    window.AureliaCart = CartStore;

    // ──────────────── Account (demo, localStorage) ─────────────
    const DEMO_USERS = {
      alice: { email: "alice.demo@aurelia-coffee.local", name: "Alice Demo" },
      bob:   { email: "bob.demo@aurelia-coffee.local",   name: "Bob Demo" },
    };
    // Mirrors the orders seeded into Medusa — used for the account page's
    // "past orders" view. In a real build the widget's backend queries
    // Medusa directly; the host page just needs a readable snapshot.
    const DEMO_ORDERS = {
      "alice.demo@aurelia-coffee.local": [
        { number: "AUR-1001", date: "2026-03-14", items: [
          { title: "Ethiopian Yirgacheffe — 250g / Whole Bean", quantity: 1, price: 1800 },
          { title: "Hario V60 02 Ceramic (White)",              quantity: 1, price: 2800 },
        ]},
        { number: "AUR-1024", date: "2026-04-01", items: [
          { title: "Aurelia House Blend — 1kg / Whole Bean",    quantity: 2, price: 5500 },
          { title: "Hario V60 02 Paper Filters 100ct",          quantity: 1, price:  700 },
        ]},
      ],
      "bob.demo@aurelia-coffee.local": [
        { number: "AUR-1008", date: "2026-03-22", items: [
          { title: "Aurelia Espresso Blend — 250g / Ground",    quantity: 1, price: 1800 },
          { title: "Bialetti Moka Express 6",                   quantity: 1, price: 3500 },
        ]},
        { number: "AUR-1039", date: "2026-04-10", items: [
          { title: "Colombian Huila — 1kg / Whole Bean",        quantity: 1, price: 5500 },
          { title: "Fellow Stagg EKG Electric Kettle",          quantity: 1, price: 18500 },
        ]},
      ],
    };
    const AccountStore = {
      key: "aurelia.account",
      current() { try { return JSON.parse(localStorage.getItem(this.key) || "null"); } catch (e) { return null; } },
      login(id) { localStorage.setItem(this.key, JSON.stringify(DEMO_USERS[id])); refreshAccountBadge(); },
      logout() { localStorage.removeItem(this.key); refreshAccountBadge(); },
      orders() { const c = this.current(); return c ? (DEMO_ORDERS[c.email] || []) : []; },
    };
    window.AureliaAccount = AccountStore;

    function refreshCartBadge() { const el = $("#cart-count"); if (el) el.textContent = CartStore.count(); }
    function refreshAccountBadge() {
      const el = $("#nav-account");
      if (!el) return;
      const c = AccountStore.current();
      el.textContent = c ? c.name.split(" ")[0] : "Sign in";
    }

    // ──────────────── Router ───────────────────────────────────
    async function route() {
      const hash = (window.location.hash || "#/").slice(1) || "/";
      const app = $("#app");
      app.innerHTML = '<div class="state">Loading…</div>';
      window.scrollTo(0, 0);
      try {
        if (hash === "/" || hash === "") return await renderHome(app);
        if (hash === "/cart")             return renderCart(app);
        if (hash === "/account")          return renderAccount(app);
        if (hash.indexOf("/p/") === 0)    return await renderProduct(app, decodeURIComponent(hash.slice(3)));
        app.innerHTML = '<div class="state">Page not found.</div>';
      } catch (err) {
        app.innerHTML = '<div class="state error">Error: ' + esc(err.message) + "</div>";
      }
    }

    // ──────────────── Renderers ────────────────────────────────
    async function renderHome(app) {
      const data = await api("/store/products?limit=50&fields=id,title,description,thumbnail,handle,variants.calculated_price");
      const products = data.products || [];
      const cards = products.map(p => {
        const amounts = (p.variants || [])
          .map(v => v.calculated_price && v.calculated_price.calculated_amount)
          .filter(x => typeof x === "number");
        const cheapest = amounts.length ? Math.min.apply(null, amounts) : null;
        const currency = (p.variants && p.variants[0] && p.variants[0].calculated_price && p.variants[0].calculated_price.currency_code) || "eur";
        const desc = (p.description || "").slice(0, 90);
        return (
          '<a class="card" href="#/p/' + encodeURIComponent(p.handle) + '">' +
            '<img src="' + esc(p.thumbnail || "") + '" alt="' + esc(p.title) + '" loading="lazy" />' +
            '<div class="body">' +
              '<h3>' + esc(p.title) + '</h3>' +
              '<p class="desc">' + esc(desc) + (p.description && p.description.length > 90 ? "…" : "") + '</p>' +
              (cheapest != null ? '<div class="price">from ' + fmt(cheapest, currency) + '</div>' : '') +
            '</div>' +
          '</a>'
        );
      }).join("");
      app.innerHTML =
        '<section class="hero">' +
          '<h1>Aurelia — Specialty Coffee</h1>' +
          '<p>Single-origin beans, house blends and the gear to brew them. This is the AI to Widget demo host — ask the assistant in the bottom-right for help choosing, then click through to any product.</p>' +
        '</section>' +
        '<section class="grid">' + (cards || '<div class="state">No products yet.</div>') + '</section>';
    }

    async function renderProduct(app, handle) {
      const data = await api("/store/products?handle=" + encodeURIComponent(handle) +
        "&fields=id,title,description,thumbnail,images.*,handle,variants.id,variants.title,variants.sku,variants.calculated_price");
      const product = (data.products || [])[0];
      if (!product) { app.innerHTML = '<div class="state">Product not found.</div>'; return; }

      const variants = product.variants || [];
      const variantLabel = (v) => {
        const price = v.calculated_price
          ? fmt(v.calculated_price.calculated_amount, v.calculated_price.currency_code)
          : "";
        return v.title + (price ? " — " + price : "");
      };
      const options = variants.map(v => '<option value="' + esc(v.id) + '">' + esc(variantLabel(v)) + '</option>').join("");

      app.innerHTML =
        '<a class="back" href="#/">← All products</a>' +
        '<div class="pdp">' +
          '<div class="gallery">' +
            '<img src="' + esc(product.thumbnail || "") + '" alt="' + esc(product.title) + '" />' +
          '</div>' +
          '<div class="info">' +
            '<h1>' + esc(product.title) + '</h1>' +
            '<p class="desc">' + esc(product.description || "") + '</p>' +
            '<div class="row">' +
              '<label for="variant">Choose option</label>' +
              '<select id="variant">' + options + '</select>' +
            '</div>' +
            '<div class="row">' +
              '<label for="qty">Quantity</label>' +
              '<input id="qty" class="qty-input" type="number" min="1" value="1" />' +
            '</div>' +
            '<button id="add-to-cart" class="btn primary">Add to cart</button>' +
            '<div id="add-feedback" class="feedback">&nbsp;</div>' +
          '</div>' +
        '</div>';

      $("#add-to-cart").addEventListener("click", () => {
        const vid = $("#variant").value;
        const qty = Math.max(1, parseInt($("#qty").value, 10) || 1);
        const variant = variants.find(v => v.id === vid);
        if (!variant) return;
        CartStore.add(product, variant, qty);
        const fb = $("#add-feedback");
        fb.textContent = "Added " + qty + " × " + variant.title + " to your cart.";
        fb.classList.add("success");
        setTimeout(() => fb.classList.remove("success"), 2500);
      });
    }

    function renderCart(app) {
      const items = CartStore.items();
      if (!items.length) {
        app.innerHTML =
          '<section class="empty">' +
            '<h1>Your cart is empty</h1>' +
            '<p><a href="#/">Browse coffees →</a></p>' +
          '</section>';
        return;
      }
      const rows = items.map(i => (
        '<tr>' +
          '<td>' +
            '<div class="cart-item">' +
              '<img src="' + esc(i.image || "") + '" alt="" />' +
              '<div>' +
                '<div>' + esc(i.title) + '</div>' +
                '<div class="muted">' + esc(i.variant_title) + '</div>' +
              '</div>' +
            '</div>' +
          '</td>' +
          '<td>' + fmt(i.price, i.currency) + '</td>' +
          '<td><input type="number" min="0" value="' + i.quantity + '" class="qty-input-small" data-vid="' + esc(i.variant_id) + '" /></td>' +
          '<td>' + fmt(i.price * i.quantity, i.currency) + '</td>' +
          '<td><button class="remove-btn" data-vid="' + esc(i.variant_id) + '" title="Remove">✕</button></td>' +
        '</tr>'
      )).join("");

      app.innerHTML =
        '<div class="cart">' +
          '<h1>Your cart</h1>' +
          '<table class="cart-table">' +
            '<thead><tr><th>Item</th><th>Unit price</th><th>Qty</th><th>Subtotal</th><th></th></tr></thead>' +
            '<tbody>' + rows + '</tbody>' +
            '<tfoot><tr>' +
              '<td colspan="3" class="align-right"><strong>Subtotal</strong></td>' +
              '<td><strong>' + fmt(CartStore.subtotal()) + '</strong></td>' +
              '<td></td>' +
            '</tr></tfoot>' +
          '</table>' +
          '<div class="cart-actions">' +
            '<button id="clear-cart" class="btn">Clear cart</button>' +
            '<button id="checkout" class="btn primary">Checkout</button>' +
          '</div>' +
        '</div>';

      $$(".qty-input-small").forEach(el => {
        el.addEventListener("change", (e) => {
          const qty = Math.max(0, parseInt(e.target.value, 10) || 0);
          CartStore.update(e.target.dataset.vid, qty);
          route();
        });
      });
      $$(".remove-btn").forEach(el => {
        el.addEventListener("click", (e) => {
          CartStore.update(e.target.closest("[data-vid]").dataset.vid, 0);
          route();
        });
      });
      $("#clear-cart").addEventListener("click", () => { CartStore.clear(); route(); });
      $("#checkout").addEventListener("click", () => {
        alert("Demo checkout — your (synthetic) order has been placed!\n\nNo real payment was processed.");
        CartStore.clear();
        location.hash = "#/";
      });
    }

    function renderAccount(app) {
      const current = AccountStore.current();
      if (!current) {
        app.innerHTML =
          '<section class="account">' +
            '<h1>Sign in</h1>' +
            '<p class="muted">This demo ships with two synthetic customers. Pick one to see their past orders. No real authentication happens.</p>' +
            '<div class="login-buttons">' +
              '<button class="btn primary" data-login="alice">Sign in as Alice Demo</button>' +
              '<button class="btn primary" data-login="bob">Sign in as Bob Demo</button>' +
            '</div>' +
          '</section>';
        $$("[data-login]").forEach(el => {
          el.addEventListener("click", (e) => { AccountStore.login(e.currentTarget.dataset.login); route(); });
        });
        return;
      }
      const orders = AccountStore.orders();
      const ordersHtml = orders.length === 0
        ? '<p class="muted">No past orders.</p>'
        : '<div class="orders">' + orders.map(o => (
            '<article class="order">' +
              '<header>' +
                '<strong>' + esc(o.number) + '</strong>' +
                '<span class="muted">' + esc(o.date) + '</span>' +
              '</header>' +
              '<ul>' + o.items.map(i =>
                '<li>' + i.quantity + ' × ' + esc(i.title) + ' — ' + fmt(i.price * i.quantity) + '</li>'
              ).join("") + '</ul>' +
            '</article>'
          )).join("") + '</div>';

      app.innerHTML =
        '<section class="account">' +
          '<div class="account-header">' +
            '<h1>Welcome back, ' + esc(current.name) + '</h1>' +
            '<button id="logout" class="btn">Sign out</button>' +
          '</div>' +
          '<p class="muted">' + esc(current.email) + '</p>' +
          '<h2>Your past orders</h2>' +
          ordersHtml +
        '</section>';
      $("#logout").addEventListener("click", () => { AccountStore.logout(); route(); });
    }

    // ──────────────── Boot ─────────────────────────────────────
    (async function () {
      refreshCartBadge();
      refreshAccountBadge();
      try { await initRegion(); }
      catch (e) { console.warn("[aurelia] region init failed:", e); }
      route();
      window.addEventListener("hashchange", route);
    })();
  </script>

  <script
    src="/widget.js"
    data-backend-url="${ATW_BACKEND_URL}"
    data-api-base-url="${MEDUSA_BACKEND_URL}"
    data-auth-mode="cookie"
    data-launcher-position="bottom-right"
    data-locale="en"
    data-intro="Hi! I'm Aurelia's assistant. Ask me anything about our coffees or brewing gear."
    data-login-url="#/account"
  ></script>
</body>
</html>
