{
  "name": "@atw/shop-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "ATW Reference Shop — Fastify backend with Prisma + JWT + OpenAPI",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/jwt": "8.0.1",
    "@fastify/swagger": "8.14.0",
    "@fastify/swagger-ui": "3.0.0",
    "@prisma/client": "5.14.0",
    "@sinclair/typebox": "0.32.31",
    "bcryptjs": "2.4.3",
    "fastify": "4.27.0",
    "pino": "9.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "^20.11.0",
    "prisma": "5.14.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.4.0"
  }
}
